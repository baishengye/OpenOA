{
  "name": "openoa-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "对标钉钉的模块化 OA App ",
  "packageManager": "pnpm@11.2.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "postinstall": "node scripts/deref-rn-gradle-plugin.js && node scripts/harmony-postinstall.js && pnpm codegen:harmony",
    "build": "pnpm -r --filter \"./packages/*\" build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean && rimraf node_modules",
    "codegen:harmony": "node scripts/harmony-codegen.js",
    "oa:install": "pnpm --filter @itc-oa/app install",
    "oa:start": "pnpm --filter @itc-oa/app start",
    "oa:harmony": "pnpm --filter @itc-oa/app harmony",
    "oa:android": "pnpm --filter @itc-oa/app android",
    "oa:ios": "pnpm --filter @itc-oa/app ios",
    "oa:bundle-android": "pnpm --filter @itc-oa/app bundle-android",
    "oa:bundle-ios": "pnpm --filter @itc-oa/app bundle-ios",
    "oa:bundle-harmony": "pnpm --filter @itc-oa/app bundle-harmony",
    "oa:clean": "pnpm --filter @itc-oa/app clean",
    "oa:uninstall": "pnpm store prune && node scripts/clean-node-modules.js",
    "ios-pod-install": "cd apps/oa/ios && bundle exec pod install",
    "oa:code-push:android-staging": "pnpm --filter @itc-oa/app code-push:android-staging",
    "oa:code-push:android-production": "pnpm --filter @itc-oa/app code-push:android-production",
    "oa:code-push:ios-staging": "pnpm --filter @itc-oa/app code-push:ios-staging",
    "oa:code-push:ios-production": "pnpm --filter @itc-oa/app code-push:ios-production",
    "oa:code-push:harmony-staging": "pnpm --filter @itc-oa/app code-push:harmony-staging  ",
    "oa:code-push:harmony-production": "pnpm --filter @itc-oa/app code-push:harmony-production",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@types/react": "^19.1.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3"
  }
}
