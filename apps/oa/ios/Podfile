# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

# react-native-permissions setup script
def node_require(script)
  require Pod::Executable.execute_command('node', ['-p',
    "require.resolve(
      '#{script}',
      {paths: [process.argv[1]]},
    )", __dir__]).strip
end
node_require('react-native-permissions/scripts/setup.rb')

platform :ios, min_ios_version_supported
prepare_react_native_project!

# react-native-permissions: 注册权限处理器
setup_permissions([
  'Camera',
  'Microphone',
  'LocationWhenInUse',
  'LocationAlways',
  'Contacts',
  'Calendars',
  'PhotoLibrary',
  'MediaLibrary',
  'Reminders',
  'SpeechRecognition',
  'Motion',
  'AppTrackingTransparency',
  'FaceID',
  'Siri',
  'StoreKit',
])

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'OpenOA' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  # OpenIM SDK TurboModule 本地 Pod
  pod 'ItcOpenIM', :path => '../../../packages/im/ios'

  post_install do |installer|
    # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # 修复 Xcode 26.5 新版 Clang 下 fmt 11.0 的 consteval 编译报错。
    # fmt/base.h 无条件按编译器重定义 FMT_USE_CONSTEVAL(忽略 -D 宏)，故直接 patch 头文件强制关闭。
    fmt_base = File.join(__dir__, 'Pods', 'fmt', 'include', 'fmt', 'base.h')
    if File.exist?(fmt_base)
      text = File.read(fmt_base)
      unless text.include?('OPENDINGDING_FMT_PATCH')
        text = text.sub(
          "#if FMT_USE_CONSTEVAL\n#  define FMT_CONSTEVAL consteval",
          "// OPENDINGDING_FMT_PATCH\n#undef FMT_USE_CONSTEVAL\n#define FMT_USE_CONSTEVAL 0\n#if FMT_USE_CONSTEVAL\n#  define FMT_CONSTEVAL consteval"
        )
        File.write(fmt_base, text)
        Pod::UI.puts '[OpenOA] patched fmt/base.h: FMT_USE_CONSTEVAL=0'
      end
    end

    # 修复 OpenIMCore XCFramework 头文件中的 @import 语法，替换为 #import 以支持非模块编译
    xcframework_base = File.join(__dir__, 'Pods', 'OpenIMSDKCore', 'Framework', 'OpenIMCore.xcframework')
    if File.exist?(xcframework_base)
      # 遍历所有archs
      Dir.glob(File.join(xcframework_base, '*')).each do |arch_dir|
        headers_dir = File.join(arch_dir, 'OpenIMCore.framework', 'Versions', 'A', 'Headers')
        if File.exist?(headers_dir)
          ['Open_im_sdk.objc.h', 'Universe.objc.h', 'Open_im_sdk_callback.objc.h'].each do |header|
            header_path = File.join(headers_dir, header)
            if File.exist?(header_path)
              text = File.read(header_path)
              if text.include?('@import') && !text.include?('OPENDINGDING_PATCHED')
                text = text.sub('@import Foundation;', '#import <Foundation/Foundation.h>')
                text = "// OPENDINGDING_PATCHED\n" + text
                File.write(header_path, text)
                Pod::UI.puts "[OpenOA] patched #{header} in #{File.basename(arch_dir)}"
              end
            end
          end
        end
      end
    end

    # 启用 CLANG_ENABLE_MODULES 以支持 @import 语法 (OpenIMSDK 内部使用 @import OpenIMCore)
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['CLANG_ENABLE_MODULES'] = 'YES'
        config.build_settings['CLANG_ENABLE_OBJC_ARC'] = 'YES'
        config.build_settings['DEFINES_MODULE'] = 'YES'
        config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= ['$(inherited)']
        config.build_settings['OTHER_CFLAGS'] ||= ['$(inherited)']
        config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++20'
      end
    end
  end
end
