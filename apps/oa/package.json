{
  "name": "@itc-oa/app",
  "version": "0.1.0",
  "private": true,
  "description": "OpenDingDing OA App 宿主（对标钉钉），消费 @itc/* 模块。",
  "op-sqlite": {
    "sqlcipher": false,
    "libsql": false
  },
  "scripts": {
    "start": "react-native start",
    "start:harmony": "hdc rport tcp:8081 tcp:8081 || true; react-native start --config metro.config.harmony.js",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "clean": "rimraf android/app/build ios/build"
  },
  "dependencies": {
    "@itc/base": "workspace:*",
    "@itc/biometric": "workspace:*",
    "@itc/db": "workspace:*",
    "@itc/im": "workspace:*",
    "@itc/push": "workspace:*",
    "@itc/storage": "workspace:*",
    "@op-engineering/op-sqlite": "^16.2.0",
    "@react-native-ohos/op-sqlite": "^14.0.1",
    "react": "19.1.1",
    "react-native": "0.82.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@babel/preset-env": "^7.25.0",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.3",
    "@react-native-community/cli-platform-android": "20.1.3",
    "@react-native-community/cli-platform-ios": "20.1.3",
    "@react-native-oh/react-native-harmony": "0.82.30",
    "@react-native-oh/react-native-harmony-cli": "0.82.30",
    "@react-native/babel-preset": "0.82.1",
    "@react-native/codegen": "0.82.1",
    "@react-native/gradle-plugin": "0.82.1",
    "@react-native/metro-config": "0.82.1",
    "@react-native/typescript-config": "0.82.1",
    "@types/react": "^19.1.1"
  }
}
