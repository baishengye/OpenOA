    "@itc/push": "workspace:*",
    "@itc/storage": "workspace:*",
    "@itc/uikit": "workspace:*",
    "@op-engineering/op-sqlite": "^16.2.0",
    "@react-native-ohos/react-native-code-push": "8.2.3",
