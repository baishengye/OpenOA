{
  "name": "@itc-oa/app",
  "version": "0.1.0",
  "private": true,
  "description": "OpenOA OA App 宿主（对标钉钉），消费 @itc/* 模块。",
  "op-sqlite": {
    "sqlcipher": false,
    "libsql": false
  },
  "scripts": {
    "start": "react-native start",
    "harmony": "node scripts/harmony-rport.mjs && react-native start --config metro.config.harmony.js",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "clean": "rimraf android/app/build ios/build",
    "bundle-android": "react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res",
    "bundle-ios": "react-native bundle --platform ios --dev false --entry-file index.js --bundle-output ios/main.jsbundle",
    "bundle-harmony": "react-native bundle --platform harmony --dev false --entry-file index.js --bundle-output harmony/entry/src/main/resources/rawfile/bundle.harmony.js --assets-dest harmony/entry/src/main/resources/rawfile --config metro.config.harmony.js",
    "code-push:android-staging": "node scripts/codepush-release.js android Staging",
    "code-push:android-production": "node scripts/codepush-release.js android Production",
    "code-push:ios-staging": "node scripts/codepush-release.js ios Staging",
    "code-push:ios-production": "node scripts/codepush-release.js ios Production",
    "code-push:harmony-staging": "node scripts/codepush-release.js harmony Staging",
    "code-push:harmony-production": "node scripts/codepush-release.js harmony Production"
  },
  "dependencies": {
    "@gorhom/portal": "^1.0.14",
    "@itc/base": "workspace:*",
    "@itc/biometric": "workspace:*",
    "@itc/db": "workspace:*",
    "@itc/document-picker": "workspace:*",
    "@itc/flash-list": "workspace:*",
    "@itc/fs": "workspace:*",
    "@itc/hotfix": "workspace:*",
    "@itc/i18n": "workspace:*",
    "@itc/permission": "workspace:*",
    "@itc/push": "workspace:*",
    "@itc/rn-client-sdk-plus": "workspace:*",
    "@itc/storage": "workspace:*",
    "@itc/uikit": "workspace:*",
    "@op-engineering/op-sqlite": "^16.2.0",
    "@react-native-documents/picker": "^12.0.1",
    "@react-native-oh-tpl/react-native-mmkv-storage": "0.10.3-0.0.2",
    "@react-native-ohos/op-sqlite": "^14.0.1",
    "@react-native-ohos/react-native-code-push": "8.2.3",
    "@react-native-ohos/react-native-document-picker": "~9.3.2",
    "@react-native-ohos/react-native-fs": "2.20.2-beta.2",
    "@react-native-ohos/react-native-permissions": "5.4.3-rc.1",
    "@react-native-ohos/react-native-safe-area-context": "5.6.3",
    "react": "19.1.1",
    "date-fns": "^4.4.0",
    "react-i18next": "^15.4.1",
    "i18next": "^24.2.3",
    "react-native": "0.82.1",
    "react-native-code-push": "^8.3.1",
    "react-native-fs-turbo": "^0.5.1",
    "react-native-mmkv-storage": "^0.11.2",
    "react-native-permissions": "^5.0.0",
    "react-native-safe-area-context": "^5.8.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@babel/preset-env": "^7.25.0",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.3",
    "@react-native-community/cli-platform-android": "20.1.3",
    "@react-native-community/cli-platform-ios": "20.1.3",
    "@react-native-oh/react-native-harmony": "0.82.30",
    "@react-native-oh/react-native-harmony-cli": "0.82.30",
    "@react-native/babel-preset": "0.82.1",
    "@react-native/codegen": "0.82.1",
    "@react-native/gradle-plugin": "0.82.1",
    "@react-native/metro-config": "0.82.1",
    "@react-native/typescript-config": "0.82.1",
    "@types/react": "^19.1.1"
  }
}
