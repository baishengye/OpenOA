# React Native 对扁平 node_modules 有强假设，pnpm 默认的符号链接结构会导致
# Metro / autolinking / codegen 解析失败，因此 monorepo 下使用 hoisted 布局。
node-linker=hoisted
shamefully-hoist=true

# 私有源：@itc scope 指向公司私有 registry（开发期可注释，用 workspace 本地 link）
# 部署前把下面一行的地址换成实际 Verdaccio / Nexus 地址
# @itc:registry=http://your-verdaccio-host:4873/

# 锁定原生工程相关二进制依赖的提升，保证 RN codegen 能找到
public-hoist-pattern[]=*react-native*
public-hoist-pattern[]=@react-native/*
public-hoist-pattern[]=@react-native-oh/*
