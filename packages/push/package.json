{
  "name": "@itc/push",
  "version": "0.0.0",
  "description": "可剥离复用的推送模块（占位骨架）：统一推送抽象，底层走第三方聚合（友盟/极光）+ iOS APNs + 鸿蒙 Push Kit。",
  "source": "./src/index.ts",
  "main": "./lib/module/index.js",
  "module": "./lib/module/index.js",
  "types": "./lib/typescript/module/index.d.ts",
  "react-native": "./src/index.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "react-native": "./src/index.ts",
      "import": {
        "types": "./lib/typescript/module/index.d.ts",
        "default": "./lib/module/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "files": ["src", "lib", "android", "ios", "harmony", "*.podspec"],
  "scripts": {
    "build": "bob build",
    "clean": "rimraf lib",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "peerDependencies": {
    "@itc/base": "workspace:*",
    "react": "*",
    "react-native": ">=0.77.0"
  },
  "devDependencies": {
    "@itc/base": "workspace:*",
    "react-native": "0.77.0",
    "react-native-builder-bob": "^0.32.1"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [["module", { "esm": true }], ["typescript", { "esm": true }]]
  },
  "publishConfig": { "access": "restricted" },
  "license": "UNLICENSED"
}
