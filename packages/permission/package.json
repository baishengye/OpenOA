{
  "name": "@itc/permission",
  "version": "0.1.0",
  "description": "OpenOA 项目的权限管理模块，通过 PermissionProvider 接口抽象权限能力，统一封装 iOS/Android/HarmonyOS 三端的原生权限 API，提供跨平台一致的权限申请体验。",
  "keywords": [
    "react-native",
    "permissions",
    "harmonyos",
    "ios",
    "android",
    "code-push"
  ],
  "license": "UNLICENSED",
  "author": "OpenOA Team",
  "main": "./lib/module/index.js",
  "module": "./lib/module/index.js",
  "types": "./lib/typescript/commonjs/index.d.ts",
  "source": "./src/index.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "react-native": "./src/index.ts",
      "import": {
        "types": "./lib/typescript/commonjs/index.d.ts",
        "default": "./lib/module/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "patches"
  ],
  "scripts": {
    "build": "bob build",
    "clean": "rimraf lib",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@itc/base": "workspace:*",
    "@react-native-ohos/react-native-permissions": "5.4.3-rc.1",
    "react-native-permissions": "^5.0.0"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": ">=0.82.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react-native": "^0.73.0",
    "react-native": "0.82.1",
    "react-native-builder-bob": "^0.32.1",
    "rimraf": "^5.0.5",
    "typescript": "^5.3.3"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "esm": true
        }
      ]
    ]
  },
  "publishConfig": {
    "access": "restricted"
  },
  "sideEffects": false
}
