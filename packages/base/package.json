{
  "name": "@itc/base",
  "version": "0.1.0",
  "description": "OpenOA 公共基座：模块契约 / Result / 平台抽象 / 事件总线 / 日志 / 存储接口。无业务、无 feature 依赖。",
  "source": "./src/index.ts",
  "main": "./lib/module/index.js",
  "module": "./lib/module/index.js",
  "types": "./lib/typescript/module/index.d.ts",
  "react-native": "./src/index.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "react-native": "./src/index.ts",
      "import": {
        "types": "./lib/typescript/module/index.d.ts",
        "default": "./lib/module/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "!**/__tests__",
    "!**/*.test.ts"
  ],
  "scripts": {
    "build": "bob build",
    "clean": "rimraf lib",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": ">=0.77.0"
  },
  "devDependencies": {
    "react-native": "0.82.1",
    "react-native-builder-bob": "^0.32.1"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      ["module", { "esm": true }],
      ["typescript", { "esm": true }]
    ]
  },
  "publishConfig": {
    "access": "restricted"
  },
  "sideEffects": false,
  "license": "UNLICENSED"
}
