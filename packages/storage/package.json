{
  "name": "@itc/storage",
  "version": "0.1.0",
  "description": "可剥离复用的 KV 持久化模块：实现 @itc/base 的 KVStorage（同步）。三端统一用 MMKV（react-native-mmkv-storage；鸿蒙走 @react-native-oh-tpl 移植包，Metro 按 .harmony 选包）。",
  "source": "./src/index.ts",
  "main": "./lib/module/index.js",
  "module": "./lib/module/index.js",
  "types": "./lib/typescript/module/index.d.ts",
  "react-native": "./src/index.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "react-native": "./src/index.ts",
      "import": {
        "types": "./lib/typescript/module/index.d.ts",
        "default": "./lib/module/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "files": ["src", "lib"],
  "scripts": {
    "build": "bob build",
    "clean": "rimraf lib",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "peerDependencies": {
    "@itc/base": "workspace:*",
    "react": "*",
    "react-native": ">=0.77.0"
  },
  "dependencies": {
    "react-native-mmkv-storage": "^0.11.2",
    "@react-native-oh-tpl/react-native-mmkv-storage": "0.10.3-0.0.2"
  },
  "devDependencies": {
    "@itc/base": "workspace:*",
    "react-native": "0.82.1",
    "react-native-builder-bob": "^0.32.1"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [["module", { "esm": true }], ["typescript", { "esm": true }]]
  },
  "publishConfig": { "access": "restricted" },
  "license": "UNLICENSED"
}
